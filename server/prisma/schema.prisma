generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  EDITOR
}

model User {
  id       String   @id @default(cuid()) @map("_id")
  name     String
  email    String   @unique
  password String
  passwordChangedAt DateTime?
  passwordResetToken String?  @unique
  passwordResetExpires DateTime?
  role Role     @default(USER)
}